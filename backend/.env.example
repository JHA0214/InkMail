PORT=3000

# 이 앱에 접속할 때 사용할 비밀번호 (이북리더기/브라우저에서 최초 1회 입력).
# 같은 네트워크의 다른 사람이 인증 없이 메일함에 접근하지 못하도록 막는 용도.
ACCESS_KEY=change-me

# 세션 쿠키 서명용 비밀키. 비워두면 서버 시작 시 임의로 생성되며(재시작 시 재로그인 필요),
# 재시작 후에도 로그인 상태를 유지하고 싶다면 임의의 긴 문자열을 직접 지정하세요.
# SESSION_SECRET=

# Kakao Mail account (mail.kakao.com)
KAKAO_EMAIL=your-id@kakao.com
# 카카오메일 설정 > POP3/IMAP > IMAP/SMTP 사용 설정 후 발급받는 앱 비밀번호
KAKAO_APP_PASSWORD=your-app-password

KAKAO_IMAP_HOST=imap.kakao.com
KAKAO_IMAP_PORT=993
